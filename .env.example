# Local development environment template.
# Copy to `.env` at the repo root (shared by backend, frontend, and rdb via
# Docker Compose) and fill in real values. Never commit `.env`.

# --- MySQL (service name `rdb` in docker-compose.yml) ---
MYSQL_HOST=rdb
MYSQL_PORT=3306
MYSQL_ROOT_PASSWORD=change-me-root-password
MYSQL_DATABASE=ai_app
MYSQL_USER=app_user
MYSQL_PASSWORD=change-me-password
# Not read by application code today; kept for tooling compatibility.
DATABASE_URL=mysql://app_user:change-me-password@rdb:3306/ai_app

# --- Auth ---
JWT_SECRET=change-me-long-random-string

# --- Chroma persistence (backend). EFS-backed `/data/chromadb` in production. ---
PERSIST_DIRECTORY=./chroma_db

# --- External APIs (required for embeddings / rerank / chat; startup succeeds
# even with invalid keys — failures only surface at request time) ---
OPENAI_API_KEY=sk-your-openai-key
COHERE_API_KEY=your-cohere-key

# --- Backend URL used by Next.js Server Actions / route handlers ---
FASTAPI_URL=http://backend:8000/api
